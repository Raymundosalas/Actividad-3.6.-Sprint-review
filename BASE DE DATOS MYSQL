CREATE DATABASE sistema_citas;

USE sistema_citas;

CREATE TABLE usuarios(
 id INT AUTO_INCREMENT PRIMARY KEY,
 usuario VARCHAR(50),
 password VARCHAR(255)
);

CREATE TABLE pacientes(
 id INT AUTO_INCREMENT PRIMARY KEY,
 nombre VARCHAR(100),
 telefono VARCHAR(20),
 correo VARCHAR(100)
);

CREATE TABLE citas(
 id INT AUTO_INCREMENT PRIMARY KEY,
 paciente_id INT,
 fecha DATE,
 hora TIME,
 observaciones TEXT,
 FOREIGN KEY(paciente_id) REFERENCES pacientes(id)
);
